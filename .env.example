# Database (any PostgreSQL provider — change this string to migrate)
DATABASE_URL=postgresql://jpr:jpr@localhost:5432/jpr

# Auth (custom JWT — no third-party dependency)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Storage (S3-compatible — works with AWS S3, MinIO, Cloudflare R2, DO Spaces)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=jpr-uploads

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ta

# Web Push / Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@yourdomain.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Cron endpoint authentication
CRON_SECRET=your-cron-secret-minimum-32-characters

# RLS role split (Wave 2.0)
MIGRATION_DATABASE_URL=postgresql://jpr_migrator:CHANGEME@localhost:5432/jpr
SYSTEM_USER_ID=
